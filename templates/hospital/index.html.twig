{% extends 'dashboard_base.html.twig' %}

{% block title %}{{ 'List of hospitals'|trans }}{% endblock %}
{% block dashboard_title %}{{ 'Hospital Registry'|trans }}{% endblock %}
{% block dashboard_subtitle %}{{ 'Overview of all medical facilities in the network'|trans }}{% endblock %}

{% block dashboard_content %}
    <div class="row mb-4">
        <div class="col-lg-12">
            <div class="medical-card p-4">
                <h5 class="fw-bold mb-4">{{ 'General statistics'|trans }}</h5>
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="p-3 rounded-4 bg-light">
                            <div class="small text-secondary mb-1">{{ 'Total Hospitals'|trans }}</div>
                            <div class="h3 fw-bold mb-0">152</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded-4 bg-light">
                            <div class="small text-secondary mb-1">{{ 'Departments'|trans }}</div>
                            <div class="h3 fw-bold mb-0">34</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded-4 bg-light">
                            <div class="small text-secondary mb-1">{{ 'Employees'|trans }}</div>
                            <div class="h3 fw-bold mb-0">12</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="medical-card p-0 overflow-hidden">
                <div class="d-flex justify-content-between align-items-center p-4 border-bottom bg-white">
                    <h5 class="fw-bold mb-0">{{ 'Hospitals'|trans }}</h5>
                    <a class="btn btn-add-primary px-4 py-2 d-flex align-items-center gap-2" href="{{ path('app_hospital_new') }}">
                        <i class="bi bi-plus-lg"></i>
                        <span>{{ 'Create'|trans }}</span>
                    </a>
                </div>
                
                <div class="table-responsive">
                    <table class="table table-management mb-0">
                        <thead>
                            <tr>
                                <th>{{ 'ID' }}</th>
                                <th>{{ 'Name'|trans }}</th>
                                <th>{{ 'Address'|trans }}</th>
                                <th>{{ 'Departments'|trans }}</th>
                                <th>{{ 'Employees'|trans }}</th>
                                <th class="text-end pe-4">{{ 'Actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for hospital in hospitals %}
                                <tr>
                                    <td>#{{ hospital.id }}</td>
                                    <td><span class="fw-bold">{{ hospital.name }}</span></td>
                                    <td>{{ hospital.address is not empty ? hospital.address.title : 'N/A' }}</td>
                                    <td>{{ hospital.departmentsCount }}</td>
                                    <td>87</td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a class="btn-table-action view" href="{{ path('app_hospital_show', {'id': hospital.id}) }}">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a href="{{ path('app_hospital_edit', {'id': hospital.id}) }}" class="btn-table-action edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted italic">
                                        {{ 'No hospitals found.'|trans }}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .btn-add-primary {
            background: var(--brand-gradient);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            transition: all 0.3s ease;
        }
        .btn-add-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
            color: white;
        }
        .btn-table-action {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }
        .btn-table-action.view {
            background: var(--brand-gradient-soft);
            color: var(--brand-color);
        }
        .btn-table-action.view:hover {
            background: var(--brand-color);
            color: white;
        }
        .btn-table-action.edit {
            background: #f1f5f9;
            color: #64748b;
        }
        .btn-table-action.edit:hover {
            background: #64748b;
            color: white;
        }
    </style>
{% endblock %}
