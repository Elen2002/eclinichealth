{% extends 'dashboard_base.html.twig' %}

{% block title %}Create New Hospital{% endblock %}
{% block dashboard_title %}Registration{% endblock %}
{% block dashboard_subtitle %}Onboard a new clinic branch to the network{% endblock %}

{% block dashboard_nav %}
    <li>
        <a href="{{ path('app_super_admin_dashboard') }}" class="nav-item-link">
            <i class="bi bi-arrow-left"></i>
            <span>Back to Network</span>
        </a>
    </li>
{% endblock %}

{% block dashboard_content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="medical-card">
            <h5 class="fw-bold mb-4">Branch Registry Details</h5>
            {{ include('hospital/_form.html.twig', {'button_label': 'Register Hospital'}) }}
        </div>
    </div>
</div>
{% endblock %}
