{% extends 'dashboard_base.html.twig' %}

{% block title %}{{ 'Department Registry'|trans }}{% endblock %}
{% block dashboard_title %}{{ 'Department Registry'|trans }}{% endblock %}
{% block dashboard_subtitle %}{{ 'Manage global medical departments and classifications'|trans }}{% endblock %}

{% block dashboard_nav %}
    <li>
        <a href="{{ path('app_super_admin_dashboard') }}" class="nav-item-link">
            <i class="bi bi-hospital"></i>
            <span>{{ 'Hospitals'|trans }}</span>
        </a>
    </li>
    <li>
        <a href="{{ path('app_department_index') }}" class="nav-item-link active">
            <i class="bi bi-diagram-3"></i>
            <span>{{ 'Departments'|trans }}</span>
        </a>
    </li>
    <li>
        <a href="{{ path('app_doctor_index') }}" class="nav-item-link">
            <i class="bi bi-people"></i>
            <span>{{ 'Doctors'|trans }}</span>
        </a>
    </li>
    <li>
        <a href="#" class="nav-item-link">
            <i class="bi bi-file-earmark-bar-graph"></i>
            <span>{{ 'Reports'|trans }}</span>
        </a>
    </li>
    <li>
        <a href="#" class="nav-item-link">
            <i class="bi bi-gear"></i>
            <span>{{ 'Settings'|trans }}</span>
        </a>
    </li>
{% endblock %}

{% block dashboard_content %}
    <div class="row">
        <div class="col-lg-12">
            <div class="medical-card p-3 mb-4 shadow-sm border-0" style="border-radius: 20px;">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <!-- Filters Group -->
                    <div class="d-flex align-items-center gap-2 flex-grow-1" style="max-width: 600px;">
                        <div class="search-box position-relative flex-grow-1">
                            <i class="bi bi-search position-absolute" style="left: 20px; top: 50%; transform: translateY(-50%); color: var(--brand-color); opacity: 0.5;"></i>
                            <input type="text" id="deptSearch" class="form-control medical-input ps-5 py-3 rounded-4 border-0 shadow-none" 
                                   placeholder="{{ 'Search departments...'|trans }}" style="background: #f1f5f9; font-size: 0.95rem; height: 52px;">
                        </div>
                    </div>

                    <!-- Actions Group -->
                    <div class="d-flex align-items-center gap-3">
                        <form action="{{ path('app_department_import') }}" method="post" enctype="multipart/form-data" id="deptImportForm" style="display: none;">
                            <input type="file" name="import_file" accept=".csv" onchange="this.closest('form').submit()">
                        </form>
                        <button class="btn btn-action-light px-3 py-2 d-flex align-items-center gap-2" onclick="document.querySelector('#deptImportForm input').click()">
                            <i class="bi bi-upload"></i> <span>{{ 'Import'|trans }}</span>
                        </button>

                        <div class="dropdown">
                            <button class="btn btn-action-light px-3 py-2 d-flex align-items-center gap-2 dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-download"></i> <span>{{ 'Export'|trans }}</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-4 animate-fade-in mt-2 p-2">
                                <li><a class="dropdown-item rounded-3 d-flex align-items-center gap-2 py-2" href="{{ path('app_department_export', {'type': 'excel'}) }}"><i class="bi bi-file-earmark-excel text-success"></i> {{ 'Excel Format'|trans }}</a></li>
                                <li><a class="dropdown-item rounded-3 d-flex align-items-center gap-2 py-2" href="{{ path('app_department_export', {'type': 'doc'}) }}"><i class="bi bi-file-earmark-word text-primary"></i> {{ 'Word Format'|trans }}</a></li>
                                <li><a class="dropdown-item rounded-3 d-flex align-items-center gap-2 py-2" href="#" onclick="window.print()"><i class="bi bi-printer text-secondary"></i> {{ 'Print View'|trans }}</a></li>
                            </ul>
                        </div>

                        <button class="btn btn-action-light px-3 py-2 d-flex align-items-center gap-2" onclick="window.print()">
                            <i class="bi bi-printer"></i> <span>{{ 'Print View'|trans }}</span>
                        </button>
                        
                        <a href="{{ path('app_department_new') }}" class="btn btn-add-primary px-4 py-2 d-flex align-items-center gap-2">
                            <i class="bi bi-plus-lg"></i> <span>{{ 'Add Department'|trans }}</span>
                        </a>
                    </div>
                </div>
            </div>

            <div class="medical-card p-0 overflow-hidden shadow-sm border-0" style="border-radius: 20px;">
                <div class="table-responsive">
                    <table class="table table-hover align-middle custom-table mb-0">
                        <thead class="text-uppercase text-secondary small font-weight-bold">
                            <tr>
                                <th class="border-0 pb-3 ps-4">{{ 'Department Name'|trans }}</th>
                                <th class="border-0 pb-3">{{ 'Linked Hospitals'|trans }}</th>
                                <th class="border-0 pb-3">{{ 'Status'|trans }}</th>
                                <th class="border-0 pb-3 text-end pe-4">{{ 'Actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody id="deptTableBody">
                        {% for dept in departments %}
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-sm rounded-circle d-flex align-items-center justify-content-center bg-soft-primary text-primary fw-bold overflow-hidden">
                                            {% if department_images[dept.id] is defined and department_images[dept.id] %}
                                                <img src="{{ department_images[dept.id] }}" alt="{{ dept.name }}" class="img-fluid w-100 h-100" style="object-fit: cover;">
                                            {% else %}
                                                {{ dept.name|first|upper }}
                                            {% endif %}
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">{{ dept.name }}</div>
                                            <div class="small text-muted">{{ dept.description|slice(0, 40) }}{{ dept.description|length > 40 ? '...' : '' }}</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        {% if dept.hospitalDepartments|length > 0 %}
                                            {% for hd in dept.hospitalDepartments|slice(0, 2) %}
                                                <span class="badge bg-light text-secondary border rounded-pill px-2 py-1">
                                                    <i class="bi bi-hospital small me-1"></i>{{ hd.hospital.name }}
                                                </span>
                                            {% endfor %}
                                            {% if dept.hospitalDepartments|length > 2 %}
                                                <span class="badge bg-soft-secondary text-secondary rounded-pill px-2 py-1">
                                                    +{{ dept.hospitalDepartments|length - 2 }} {{ 'more'|trans }}
                                                </span>
                                            {% endif %}
                                        {% else %}
                                            <span class="text-muted small italic">{{ 'Not linked yet'|trans }}</span>
                                        {% endif %}
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-soft-success text-success px-3 py-2 rounded-pill d-inline-flex align-items-center gap-1">
                                        <div class="bg-success rounded-circle" style="width: 6px; height: 6px;"></div>
                                        {{ 'Active'|trans }}
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="{{ path('app_department_show', {'id': dept.id}) }}" class="btn-table-action view" title="{{ 'View details'|trans }}">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="{{ path('app_department_edit', {'id': dept.id}) }}" class="btn-table-action edit" title="{{ 'Edit'|trans }}">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center py-5 text-secondary italic">
                                    {{ 'No departments registered yet.'|trans }}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
<style>
    :root {
        --soft-primary: rgba(99, 102, 241, 0.1);
        --soft-success: rgba(16, 185, 129, 0.1);
        --soft-secondary: rgba(148, 163, 184, 0.1);
    }
    .medical-card {
        background: white;
        border-radius: 1.5rem;
    }
    .custom-table th {
        font-size: 0.75rem;
        letter-spacing: 0.05rem;
        padding-top: 1.5rem !important;
        background: #f8fafc;
    }
    .custom-table td {
        padding: 1.25rem 0.75rem;
        font-size: 0.9rem;
    }
    .avatar-sm {
        width: 40px;
        height: 40px;
    }
    .bg-soft-primary { background-color: var(--soft-primary); }
    .bg-soft-success { background-color: var(--soft-success); }
    .bg-soft-secondary { background-color: var(--soft-secondary); }
    
    .btn-action-light {
        background: var(--brand-gradient-soft);
        color: var(--brand-color);
        border: 1px solid rgba(99, 102, 241, 0.1);
        border-radius: 14px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        height: 48px;
    }
    .btn-action-light:hover {
        background: var(--brand-color);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
    }
    .btn-add-primary {
        background: var(--brand-gradient);
        color: white;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        height: 48px;
        box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
    }
    .btn-add-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(99, 102, 241, 0.4);
        color: white;
    }
    .btn-table-action {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        border: none;
        font-size: 1.1rem;
    }
    .btn-table-action.view {
        background: var(--brand-gradient-soft);
        color: var(--brand-color);
    }
    .btn-table-action.view:hover {
        background: var(--brand-color);
        color: white;
        transform: rotate(15deg) scale(1.1);
    }
    .btn-table-action.edit {
        background: rgba(148, 163, 184, 0.1);
        color: #64748b;
    }
    .btn-table-action.edit:hover {
        background: #64748b;
        color: white;
        transform: rotate(-15deg) scale(1.1);
    }
</style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('deptSearch');
    const tableRows = document.querySelectorAll('#deptTableBody tr');

    function filterTable() {
        const query = searchInput.value.toLowerCase();
        tableRows.forEach(row => {
            const text = row.innerText.toLowerCase();
            row.style.display = text.includes(query) ? '' : 'none';
        });
    }

    if (searchInput) searchInput.addEventListener('input', filterTable);
});
</script>
{% endblock %}
