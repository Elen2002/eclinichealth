{% extends 'dashboard_base.html.twig' %}

{% block dashboard_title %}{{ 'Doctor Registry'|trans }}{% endblock %}
{% block dashboard_subtitle %}{{ 'Manage medical staff and assignments'|trans }}{% endblock %}

{% block dashboard_content %}
    <div class="row">
        <div class="col-lg-12">
            <div class="medical-card p-3 mb-4 shadow-sm border-0" style="border-radius: 20px;">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <!-- Filters Group -->
                    <div class="d-flex align-items-center gap-3 flex-grow-1" style="max-width: 700px;">
                        <div class="search-box position-relative flex-grow-1">
                            <i class="bi bi-search position-absolute" style="left: 20px; top: 50%; transform: translateY(-50%); color: var(--brand-color); opacity: 0.5;"></i>
                            <input type="text" id="doctorSearch" class="form-control medical-input ps-5 py-3 rounded-4 border-0 shadow-none" 
                                   placeholder="{{ 'Search doctors...'|trans }}" style="background: #f1f5f9; font-size: 0.95rem; height: 52px;">
                        </div>
                        <div class="position-relative" style="width: 240px;">
                            <i class="bi bi-filter position-absolute" style="left: 15px; top: 50%; transform: translateY(-50%); color: var(--brand-color); opacity: 0.5; z-index: 5;"></i>
                            <select id="hospitalFilter" class="form-select medical-input ps-5 py-3 rounded-4 border-0 shadow-none" style="background: #f1f5f9; font-size: 0.95rem; height: 52px; cursor: pointer;">
                                <option value="All Hospitals" selected>{{ 'All Hospitals'|trans }}</option>
                                {% for hospital in hospitals %}
                                    <option value="{{ hospital.id }}">{{ hospital.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <!-- Actions Group -->
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-action-light px-3 py-2 d-flex align-items-center gap-2">
                            <i class="bi bi-upload"></i> <span>{{ 'Import'|trans }}</span>
                        </button>

                        <div class="dropdown">
                            <button class="btn btn-action-light px-3 py-2 d-flex align-items-center gap-2 dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-download"></i> <span>{{ 'Export'|trans }}</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-4 animate-fade-in mt-2 p-2">
                                <li><a class="dropdown-item rounded-3 d-flex align-items-center gap-2 py-2" href="#"><i class="bi bi-file-earmark-excel text-success"></i> Excel</a></li>
                                <li><a class="dropdown-item rounded-3 d-flex align-items-center gap-2 py-2" href="#"><i class="bi bi-file-earmark-text text-primary"></i> CSV</a></li>
                            </ul>
                        </div>

                        <button class="btn btn-action-light px-3 py-2 d-flex align-items-center gap-2" onclick="window.print()">
                            <i class="bi bi-printer"></i> <span>{{ 'Print'|trans }}</span>
                        </button>
                        
                        <button class="btn btn-add-primary px-4 py-2 d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#addDoctorModal">
                            <i class="bi bi-plus-lg"></i> <span>{{ 'Add Doctor'|trans }}</span>
                        </button>
                    </div>
                </div>
            </div>

            <div class="medical-card card-white p-0 overflow-hidden shadow-sm border-0" style="border-radius: 20px;">
                <div class="table-responsive">
                    <table class="table table-hover align-middle custom-table mb-0">
                        <thead class="text-uppercase text-secondary small font-weight-bold">
                            <tr>
                                <th class="border-0 pb-3">{{ 'Doctor Name'|trans }}</th>
                                <th class="border-0 pb-3">{{ 'Hospital Link'|trans }}</th>
                                <th class="border-0 pb-3">{{ 'Department'|trans }}</th>
                                <th class="border-0 pb-3">{{ 'Phone'|trans }}</th>
                                <th class="border-0 pb-3">{{ 'Status'|trans }}</th>
                                <th class="border-0 pb-3 text-end">{{ 'Actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody id="doctorTableBody">
                            {% for doctor in doctors %}
                                <tr data-hospital="{{ doctor.hospital.name|default('') }}">
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-sm rounded-circle d-flex align-items-center justify-content-center bg-light text-primary font-weight-bold">
                                                {{ doctor.user.email|default('Admin')|first|upper }}
                                            </div>
                                            <div>
                                                <div class="font-weight-bold text-primary">{{ doctor.user.email|default('No Email') }}</div>
                                                <div class="small text-secondary">{{ doctor.roleType|default('Specialist') }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="d-flex align-items-center gap-2 text-secondary">
                                            <i class="bi bi-hospital small"></i>
                                            {{ doctor.hospital.name|default('Not Linked') }}
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill">
                                            {{ doctor.department.name|default('Not Assigned') }}
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-secondary small">{{ doctor.phone|default('N/A') }}</span>
                                    </td>
                                    <td>
                                        {% if doctor.isActive %}
                                            <span class="badge bg-soft-success text-success px-3 py-2 rounded-pill d-inline-flex align-items-center gap-1">
                                                <div class="bg-success rounded-circle" style="width: 6px; height: 6px;"></div>
                                                {{ 'Active'|trans }}
                                            </span>
                                        {% else %}
                                            <span class="badge bg-soft-secondary text-secondary px-3 py-2 rounded-pill d-inline-flex align-items-center gap-1">
                                                <div class="bg-secondary rounded-circle" style="width: 6px; height: 6px;"></div>
                                                {{ 'Inactive'|trans }}
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn-table-action view" title="{{ 'View'|trans }}" onclick="alert('Viewing doctor details...')">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn-table-action edit" title="{{ 'Edit'|trans }}" onclick="alert('Editing doctor...')">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-secondary italic">
                                        {{ 'No doctors registered yet.'|trans }}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
<style>
    :root {
        --soft-primary: rgba(124, 58, 237, 0.1);
        --soft-success: rgba(16, 185, 129, 0.1);
    }
    .medical-card {
        border-radius: 1.5rem;
        border: none;
    }
    .custom-table th {
        font-size: 0.75rem;
        letter-spacing: 0.05rem;
        padding: 1.25rem 1.5rem !important;
        background: #f8fafc;
    }
    .custom-table td {
        padding: 1.25rem 1.5rem;
        font-size: 0.9rem;
    }
    .avatar-sm {
        width: 40px;
        height: 40px;
    }
    .bg-soft-primary { background-color: var(--soft-primary); }
    .bg-soft-success { background-color: var(--soft-success); }
    .bg-soft-secondary { background-color: rgba(108, 117, 125, 0.1); }
    
    .btn-action-light {
        background: var(--brand-gradient-soft);
        color: var(--brand-color);
        border: 1px solid rgba(99, 102, 241, 0.1);
        border-radius: 14px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        height: 48px;
    }
    .btn-action-light:hover {
        background: var(--brand-color);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
    }
    .btn-add-primary {
        background: var(--brand-gradient);
        color: white;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        height: 48px;
        box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
    }
    .btn-add-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(99, 102, 241, 0.4);
        color: white;
    }
    .btn-table-action {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        border: none;
        font-size: 1.1rem;
    }
    .btn-table-action.view {
        background: var(--brand-gradient-soft);
        color: var(--brand-color);
    }
    .btn-table-action.view:hover {
        background: var(--brand-color);
        color: white;
        transform: rotate(15deg) scale(1.1);
    }
    .btn-table-action.edit {
        background: rgba(148, 163, 184, 0.1);
        color: #64748b;
    }
    .btn-table-action.edit:hover {
        background: #64748b;
        color: white;
        transform: rotate(-15deg) scale(1.1);
    }
</style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('doctorSearch');
    const hospitalFilter = document.getElementById('hospitalFilter');
    const tableRows = document.querySelectorAll('#doctorTableBody tr');

    function filterTable() {
        const query = searchInput.value.toLowerCase();
        const hospital = hospitalFilter.value === 'All Hospitals' ? '' : hospitalFilter.options[hospitalFilter.selectedIndex].text.toLowerCase();

        tableRows.forEach(row => {
            const text = row.innerText.toLowerCase();
            const hospitalText = row.getAttribute('data-hospital').toLowerCase();
            
            const matchesSearch = text.includes(query);
            const matchesHospital = hospital === '' || hospitalText.includes(hospital);

            row.style.display = matchesSearch && matchesHospital ? '' : 'none';
        });
    }

    if (searchInput) searchInput.addEventListener('input', filterTable);
    if (hospitalFilter) hospitalFilter.addEventListener('change', filterTable);
});
</script>
{% endblock %}
