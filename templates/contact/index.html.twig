{% extends 'frontend_layout/index.html.twig' %}

{% block title %}{{ 'nav.contact'|trans }}{% endblock %}

{% block body %}
{% set locale = app.request.locale %}
<div class="contact-page pt-3 mt-4">
    <div class="container py-3">
        <div class="section-title text-center mb-4" data-aos="fade-up">
            <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-2 fw-bold text-uppercase">
                {{ 'nav.contact'|trans }}
            </span>
            <h2 class="display-5 fw-bold mb-3">{{ 'nav.contact'|trans }}</h2>
            <p class="text-muted lead mx-auto mb-0" style="max-width: 700px;">
                {{ 'contact.subtitle'|trans }}
            </p>
        </div>

        <div class="row g-4">
            <div class="col-lg-4" data-aos="fade-right">
                <div class="card h-100 border-0 shadow-sm p-4 rounded-4">
                    <div class="info-item d-flex mb-4">
                        <div class="icon-box bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                            <i class="bi bi-geo-alt fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">{{ 'contact.location'|trans }}</h5>
                            <p class="text-muted mb-0">{{ 'contact.address_val'|trans }}</p>
                        </div>
                    </div>

                    <div class="info-item d-flex mb-4">
                        <div class="icon-box bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                            <i class="bi bi-envelope fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">{{ 'contact.email'|trans }}</h5>
                            <p class="text-muted mb-0">info@eclinic.am</p>
                        </div>
                    </div>

                    <div class="info-item d-flex">
                        <div class="icon-box bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                            <i class="bi bi-phone fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">{{ 'contact.call'|trans }}</h5>
                            <p class="text-muted mb-0">+374 10 000000</p>
                        </div>
                    </div>

                    <div class="mt-4 pt-4 border-top">
                        <h6 class="fw-bold mb-3 text-uppercase small text-muted">{{ 'contact.workingHours'|trans }}</h6>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-dark">{{ 'contact.monFri'|trans }}</span>
                            <span class="text-muted">9:00 AM - 6:00 PM</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-dark">{{ 'contact.satSun'|trans }}</span>
                            <span class="text-muted">{{ 'contact.closed'|trans }}</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8" data-aos="fade-left">
                <div class="card border-0 shadow-sm p-4 h-100 rounded-4">
                    <form class="php-email-form">
                        <div class="row gy-4">
                            <div class="col-md-6">
                                <label for="name-field" class="pb-2 fw-semibold">{{ 'contact.yourName'|trans }}</label>
                                <input type="text" name="name" id="name-field" class="form-control rounded-3 py-2" required>
                            </div>

                            <div class="col-md-6">
                                <label for="email-field" class="pb-2 fw-semibold">{{ 'contact.yourEmail'|trans }}</label>
                                <input type="email" class="form-control rounded-3 py-2" name="email" id="email-field" required>
                            </div>

                            <div class="col-md-12">
                                <label for="subject-field" class="pb-2 fw-semibold">{{ 'contact.subject'|trans }}</label>
                                <input type="text" class="form-control rounded-3 py-2" name="subject" id="subject-field" required>
                            </div>

                            <div class="col-md-12">
                                <label for="message-field" class="pb-2 fw-semibold">{{ 'contact.message'|trans }}</label>
                                <textarea class="form-control rounded-3" name="message" rows="5" id="message-field" required></textarea>
                            </div>

                            <div class="col-md-12 text-center">
                                <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill fw-bold">{{ 'contact.send'|trans }}</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
