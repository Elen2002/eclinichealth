{% extends 'base.html.twig' %}

{% block title %}Login - eclinic-health{% endblock %}

{% block body %}
    <div class="auth-wrapper min-vh-100 d-flex align-items-stretch" style="background: var(--background-color);">
        <!-- Side Branding Panel -->
        <div class="auth-side d-none d-lg-flex flex-column justify-content-between p-5 text-white" 
             style="width: 40%; background: var(--brand-gradient); position: relative; overflow: hidden;">
            <div class="auth-blob position-absolute top-0 start-0 w-100 h-100 opacity-25" 
                 style="background-image: radial-gradient(circle at 20% 30%, rgba(255,255,255,0.3) 0%, transparent 50%), radial-gradient(circle at 80% 70%, rgba(255,255,255,0.2) 0%, transparent 50%);"></div>
            
            <div class="position-relative">
                <a href="{{ path('app_home') }}" class="text-white text-decoration-none d-flex align-items-center gap-2 mb-5">
                    <img src="{{ asset('build/img/header-logo.png') }}" alt="Logo" class="img-fluid" style="max-height: 48px;">
                </a>
                
                <div class="mt-5">
                    <h1 class="display-4 fw-bold mb-4 text-white" style="line-height: 1.1;">{{ 'Your Health, Unified.'|trans }}</h1>
                    <p class="lead text-white opacity-75">{{ 'Access your medical records, book appointments, and consult with specialists all in one place.'|trans }}</p>
                </div>

                <div class="mt-5 pt-4 d-none d-xl-block">
                    <div class="d-flex flex-column gap-3">
                        <div class="p-3 rounded-4 transition-all hover-translate-y" style="background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2); width: 85%;">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center text-primary flex-shrink-0" style="width: 48px; height: 48px;">
                                    <i class="bi bi-shield-check fs-4" style="color: var(--brand-color);"></i>
                                </div>
                                <div>
                                    <h5 class="mb-1 fw-bold text-white">{{ 'Secure & Private'|trans }}</h5>
                                    <p class="mb-0 small text-white opacity-75">{{ 'Your medical data is encrypted and safe.'|trans }}</p>
                                </div>
                            </div>
                        </div>
                        <div class="p-3 rounded-4 transition-all hover-translate-y ms-4" style="background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2); width: 85%;">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center text-primary flex-shrink-0" style="width: 48px; height: 48px;">
                                    <i class="bi bi-clock-history fs-4" style="color: var(--brand-color);"></i>
                                </div>
                                <div>
                                    <h5 class="mb-1 fw-bold text-white">{{ '24/7 Access'|trans }}</h5>
                                    <p class="mb-0 small text-white opacity-75">{{ 'Reach out to our specialists anytime.'|trans }}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="position-relative small opacity-50">
                &copy; {{ "now"|date("Y") }} eClinic Health. {{ 'Premium Healthcare Solutions.'|trans }}
            </div>
        </div>

        <!-- Form Panel -->
        <div class="auth-form-panel flex-grow-1 d-flex align-items-center justify-content-center p-4">
            <div class="w-100" style="max-width: 420px;">
                <div class="text-center mb-5 d-lg-none">
                    <img src="{{ asset('build/img/header-logo.png') }}" alt="Logo" class="img-fluid mb-3" style="max-height: 48px;">
                </div>

                <div class="mb-4">
                    <h2 class="fw-bold text-dark">{{ 'Welcome Back'|trans }}</h2>
                    <p class="text-muted">{{ 'Please sign in to access your health portal'|trans }}</p>
                </div>

                <form method="post">
                    {% if error %}
                        <div class="alert alert-danger mb-4 border-0 shadow-sm" style="border-radius: 12px; background: #fff1f2; color: #e11d48;">
                            <i class="bi bi-exclamation-circle me-2"></i> {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <div class="mb-3">
                        <label for="username" class="form-label small fw-bold text-dark">{{ 'Email Address'|trans }}</label>
                        <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control medical-input py-3" autocomplete="email" required autofocus placeholder="name@example.com">
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between">
                            <label for="password" class="form-label small fw-bold text-dark">{{ 'Password'|trans }}</label>
                            <a href="#" class="small text-decoration-none fw-semibold" style="color: var(--accent-color);">{{ 'Forgot?'|trans }}</a>
                        </div>
                        <input type="password" name="_password" id="password" class="form-control medical-input py-3" autocomplete="current-password" required placeholder="••••••••">
                    </div>

                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                    <button class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-lg transition-all hover-translate-y mb-4" 
                            style="background: var(--brand-gradient); border: none;">
                        {{ 'Sign In'|trans }} <i class="bi bi-arrow-right ms-2"></i>
                    </button>

                    <div class="text-center">
                        <span class="text-muted small">{{ "Don't have an account?"|trans }}</span>
                        <a href="{{ path('app_register') }}" class="small fw-bold text-decoration-none ms-1" style="color: var(--accent-color);">{{ 'Register now'|trans }}</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

{% endblock %}
