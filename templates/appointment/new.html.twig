{% extends 'frontend_layout/index.html.twig' %}

{% block title %}Book Appointment{% endblock %}

{% block body %}
    <section id="appointment" class="appointment section">
        <div class="container" data-aos="fade-up">

            <div class="section-title">
                <h2>{{ 'Book an Appointment'|trans }}</h2>
                <p>{{ 'with Dr.'|trans }} {{ doctor.user.email }}</p>
            </div>

            <div class="row justify-content-center">
                <div class="col-lg-8">
                    {{ form_start(form, {'attr': {'class': 'php-email-form'}}) }}
                    
                    <div class="mb-3">
                        {{ form_label(form.requestedDate) }}
                        {{ form_widget(form.requestedDate) }}
                        {{ form_errors(form.requestedDate) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.message) }}
                        {{ form_widget(form.message) }}
                        {{ form_errors(form.message) }}
                    </div>

                    <div class="text-center">
                        <button type="submit">{{ 'Request Appointment'|trans }}</button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>

        </div>
    </section>
{% endblock %}
