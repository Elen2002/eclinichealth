{% extends 'frontend_layout/index.html.twig' %}

{% block title %}{{ 'My Consultations'|trans }}{% endblock %}

{% block body %}
<div class="container py-5 mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold">{{ 'My Consultations'|trans }}</h1>
        <a href="{{ path('app_doctor_dashboard') }}" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left me-1"></i> {{ 'Back to Dashboard'|trans }}
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small">
                        <tr>
                            <th class="ps-4">{{ 'Patient'|trans }}</th>
                            <th>{{ 'Contact'|trans }}</th>
                            <th>{{ 'Requested Date'|trans }}</th>
                            <th>{{ 'Status'|trans }}</th>
                            <th>{{ 'Message'|trans }}</th>
                            <th class="text-end pe-4">{{ 'Actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for consultation in consultations %}
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">{{ consultation.patientName }}</div>
                                </td>
                                <td>
                                    <div>{{ consultation.patientEmail }}</div>
                                    <small class="text-muted">{{ consultation.patientPhone }}</small>
                                </td>
                                <td>
                                    <div>{{ consultation.requestedDate|date('M d, Y') }}</div>
                                    <small class="text-muted">{{ consultation.requestedDate|date('H:i') }}</small>
                                </td>
                                <td>
                                    {% if consultation.status == 'pending' %}
                                        <span class="badge bg-warning-subtle text-warning rounded-pill">{{ 'Pending'|trans }}</span>
                                    {% elseif consultation.status == 'confirmed' %}
                                        <span class="badge bg-success-subtle text-success rounded-pill">{{ 'Confirmed'|trans }}</span>
                                    {% else %}
                                        <span class="badge bg-secondary-subtle text-secondary rounded-pill">{{ consultation.status|capitalize }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="text-muted small text-truncate d-inline-block" style="max-width: 150px;">
                                        {{ consultation.message }}
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    {% if consultation.status == 'pending' %}
                                        <a href="{{ path('app_consultation_process', {'id': consultation.id}) }}" class="btn btn-sm btn-primary rounded-pill px-3">{{ 'Approve'|trans }}</a>
                                    {% else %}
                                        <a href="{{ path('app_consultation_details', {'id': consultation.id}) }}" class="btn btn-sm btn-outline-secondary rounded-pill px-3">{{ 'Details'|trans }}</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-calendar-x fs-1 d-block mb-3 opacity-25"></i>
                                    {{ 'No consultations found.'|trans }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
