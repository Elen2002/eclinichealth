{% extends 'frontend_layout/index.html.twig' %}

{% block title %}{{ 'Consultation Details'|trans }}{% endblock %}

{% block body %}
<div class="container py-5 mt-5">
    <div class="row align-items-center mb-5">
        <div class="col">
            <h1 class="h3 fw-bold mb-0 text-dark">{{ 'Consultation Details'|trans }}</h1>
        </div>
        <div class="col-auto">
            <a href="{{ path('app_doctor_dashboard') }}" class="btn btn-sm rounded-pill px-3 shadow-sm transition-all d-inline-flex align-items-center" style="background: rgba(133, 96, 205, 0.08); color: var(--brand-color); border: 1px solid rgba(133, 96, 205, 0.2); font-weight: 600; font-size: 0.85rem; height: 36px;">
                <i class="bi bi-chevron-left small me-1"></i> {{ 'Back'|trans }}
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Patient Info -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <div class="bg-primary-subtle rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;">
                         <span class="fs-2 fw-bold text-primary">{{ consultation.patientName|slice(0, 1)|upper }}</span>
                    </div>
                    <h4 class="fw-bold mb-1">{{ consultation.patientName }}</h4>
                    <p class="text-muted mb-3">{{ consultation.patientEmail }}</p>
                    <div class="d-flex justify-content-center gap-2">
                        <a href="mailto:{{ consultation.patientEmail }}" class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center transition-all shadow-sm" style="width: 38px; height: 38px; background: #fff; color: var(--brand-color); border: 1px solid #eee;">
                            <i class="bi bi-envelope"></i>
                        </a>
                        <a href="tel:{{ consultation.patientPhone }}" class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center transition-all shadow-sm" style="width: 38px; height: 38px; background: #fff; color: var(--brand-color); border: 1px solid #eee;">
                            <i class="bi bi-telephone"></i>
                        </a>
                    </div>
                    <hr class="my-4">
                    <div class="text-start">
                        <label class="small text-muted fw-bold text-uppercase">{{ 'Patient Note'|trans }}</label>
                        <p class="mt-1 bg-light p-3 rounded-3 small">{{ consultation.message }}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Appointment Info -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <div class="d-flex justify-content-between align-items-center">
                         <h5 class="fw-bold mb-0">{{ 'Appointment Summary'|trans }}</h5>
                         {% if consultation.status == 'confirmed' %}
                             <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">{{ 'Confirmed'|trans }}</span>
                         {% else %}
                             <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3 py-2">{{ consultation.status|capitalize }}</span>
                         {% endif %}
                    </div>
                </div>
                <div class="card-body p-4">
                     <div class="row g-4 mb-4">
                         <div class="col-md-6">
                             <div class="p-3 bg-light rounded-3">
                                 <label class="small text-muted fw-bold">{{ 'Requested Date'|trans }}</label>
                                 <div class="fw-bold fs-5">{{ consultation.requestedDate|date('M d, Y H:i') }}</div>
                             </div>
                         </div>
                         <div class="col-md-6">
                             <div class="p-3 bg-primary-subtle text-primary rounded-3 border border-primary-subtle">
                                 <label class="small opacity-75 fw-bold">{{ 'Confirmed Date'|trans }}</label>
                                 <div class="fw-bold fs-5">{{ consultation.doctorProposedDate ? consultation.doctorProposedDate|date('M d, Y H:i') : '-' }}</div>
                             </div>
                         </div>
                     </div>

                     <h6 class="fw-bold mb-3 border-bottom pb-2">{{ 'Medical Notes'|trans }}</h6>
                     
                     <div class="mb-4">
                         <label class="small text-muted fw-bold">{{ 'Prescription'|trans }}</label>
                         {% if consultation.prescription %}
                             <div class="mt-1">{{ consultation.prescription|nl2br }}</div>
                         {% else %}
                             <div class="mt-1 text-muted fst-italic">{{ 'No prescription provided.'|trans }}</div>
                         {% endif %}
                     </div>

                     <div class="mb-4">
                         <label class="small text-muted fw-bold">{{ 'Required Tests'|trans }}</label>
                         {% if consultation.medicalTests %}
                             <div class="mt-1">{{ consultation.medicalTests|nl2br }}</div>
                         {% else %}
                             <div class="mt-1 text-muted fst-italic">{{ 'No tests required.'|trans }}</div>
                         {% endif %}
                     </div>

                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
