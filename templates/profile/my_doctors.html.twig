{% extends 'frontend_layout/index.html.twig' %}

{% block title %}{{ 'My Doctors'|trans }}{% endblock %}

{% block body %}
<div class="doctors-page min-vh-100 mt-5 pt-4" style="background: var(--background-color);">
    <!-- Hero Section -->
    <div class="doctors-hero py-5 mb-5" style="background: linear-gradient(135deg, var(--brand-color), var(--accent-color));">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-7 text-center text-md-start text-white">
                    <h1 class="fw-bold mb-2 text-white"><i class="bi bi-person-heart me-2"></i>{{ 'My Doctors'|trans }}</h1>
                    <p class="text-white-50 fs-5 mb-0">{{ 'Manage your connections with medical specialists.'|trans }}</p>
                </div>
                <div class="col-md-5 text-center text-md-end mt-4 mt-md-0">
                    <a href="{{ path('app_profile') }}" class="btn btn-white btn-sm rounded-pill px-4 shadow-sm border d-inline-flex align-items-center justify-content-center" style="font-weight: 600; width: fit-content; min-width: 160px; height: 38px; font-size: 0.8rem;">
                        <i class="bi bi-arrow-left me-2"></i> {{ 'Back to Profile'|trans }}
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="container pb-5">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="background: var(--surface-color);">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase tracking-wider">
                            <tr>
                                <th class="ps-4 py-3 border-0">{{ 'Doctor'|trans }}</th>
                                <th class="border-0">{{ 'Specialty'|trans }}</th>
                                <th class="border-0">{{ 'Hospital'|trans }}</th>
                                <th class="border-0">{{ 'Contact'|trans }}</th>
                                <th class="border-0 pe-4 text-end">{{ 'Actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for dr in my_doctors %}
                                <tr class="transition-all">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3 py-2">
                                            <div class="position-relative">
                                                <img src="{{ dr.user.avatar|default('/img/default-doctor.png') }}" 
                                                     class="rounded-circle shadow-sm border border-2 border-white"
                                                     style="width: 50px; height: 50px; object-fit: cover;" alt="">
                                                <span class="position-absolute bottom-0 end-0 {{ dr.isActive ? 'bg-success' : 'bg-secondary' }} border border-2 border-white rounded-circle" 
                                                      style="width: 12px; height: 12px;"></span>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">{{ dr.user.firstName or dr.user.lastName ? dr.user.firstName ~ ' ' ~ dr.user.lastName : dr.user.email|split('@')[0]|capitalize }}</div>
                                                <div class="text-muted small">{{ dr.roleType|capitalize|trans|default('') }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="badge bg-primary-subtle text-primary rounded-pill px-3 py-1 small">
                                            {{ dr.specialty|default(dr.department.name|default('General'|trans)) }}
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small text-muted">
                                            <i class="bi bi-hospital me-1"></i> {{ dr.hospital.name|default('EClinic Health') }}
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small mb-1"><i class="bi bi-envelope me-1"></i> {{ dr.user.email }}</div>
                                        {% if dr.phone %}
                                            <div class="small text-muted"><i class="bi bi-telephone me-1"></i> {{ dr.phone }}</div>
                                        {% endif %}
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a href="{{ path('app_consultation_new', { 
                                                'doctor': dr.id,
                                                'hospital': dr.hospital.id|default(''),
                                                'department': dr.department.id|default('')
                                            }) }}" class="btn btn-sm btn-gradient-purple rounded-pill px-3 shadow-sm fw-bold">
                                                <i class="bi bi-calendar-plus me-1"></i> {{ 'Book'|trans }}
                                            </a>
                                             <a href="{{ path('app_profile_chat', {'doctorId': dr.id}) }}" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm fw-bold d-flex align-items-center gap-2">
                                                 <i class="bi bi-chat-dots"></i> {{ 'Message'|trans }}
                                             </a>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <div class="py-5">
                                            <i class="bi bi-people fs-1 text-muted opacity-25 d-block mb-3"></i>
                                            <h4 class="text-muted fw-bold">{{ 'No doctors found.'|trans }}</h4>
                                            <p class="text-muted mb-4">{{ 'You haven\'t had any consultations yet.'|trans }}</p>
                                            <a href="{{ path('app_hospital_public_list') }}" class="btn btn-primary rounded-pill px-4" style="width: fit-content; min-width: 180px;">
                                                {{ 'Browse Hospitals'|trans }}
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .doctors-hero {
        position: relative;
        overflow: hidden;
    }
    .doctors-hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.1) 0%, transparent 40%),
                          radial-gradient(circle at 90% 80%, rgba(255, 255, 255, 0.05) 0%, transparent 40%);
    }
    .btn-white {
        background: var(--surface-color);
        color: var(--brand-color);
        border: none;
        transition: all 0.3s ease;
    }
    .btn-white:hover {
        background: #f8f9fa;
        transform: translateY(-2px);
        color: var(--brand-color);
    }
    .hover-shadow:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
    }
    .transition-all {
        transition: all 0.3s ease;
    }
    .btn-gradient-purple {
        background: linear-gradient(135deg, var(--brand-color), var(--accent-color));
        color: white;
        border: none;
    }
    .btn-gradient-purple:hover {
        filter: brightness(1.1);
        transform: translateY(-1px);
        box-shadow: 0 5px 15px rgba(99, 102, 241, 0.3);
        color: white;
    }
    .btn-white-modern {
        background: var(--surface-color) !important;
        color: var(--brand-color) !important;
        border: 1px solid #eee !important;
        transition: all 0.3s ease;
    }
    .btn-white-modern:hover {
        background: var(--surface-color) !important;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.05) !important;
        border-color: var(--brand-color) !important;
    }
</style>
{% endblock %}
