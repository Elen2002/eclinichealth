{% extends 'frontend_layout/index.html.twig' %}

{% block title %}{{ 'My Doctors'|trans }}{% endblock %}

{% block body %}
<div class="doctors-page min-vh-100 mt-5 pt-4" style="background: var(--background-color);">
    <!-- Hero Section -->
    <div class="doctors-hero py-4 py-md-5 mb-4 mb-md-5" style="background: linear-gradient(135deg, var(--brand-color), var(--accent-color));">
        <div class="container position-relative" style="z-index: 1;">
            <div class="row align-items-center">
                <div class="col-md-7 text-white">
                    <h1 class="fw-bold mb-2 text-white fs-3 fs-md-1">
                        <i class="bi bi-person-heart me-2"></i>{{ 'My Doctors'|trans }}
                    </h1>
                    <p class="text-white-50 mb-0 small">{{ 'Manage your connections with medical specialists.'|trans }}</p>
                </div>
                <div class="col-md-5 text-md-end mt-3 mt-md-0">
                    <a href="{{ path('app_profile') }}" class="btn btn-white btn-sm rounded-pill px-4 shadow-sm border d-inline-flex align-items-center gap-2" style="font-weight: 600; height: 38px; font-size: 0.82rem;">
                        <i class="bi bi-arrow-left"></i> {{ 'Back to Profile'|trans }}
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="container pb-5">

        {# ─────────────── MOBILE CARDS (shown on xs–md) ─────────────── #}
        <div class="d-md-none">
            {% for dr in my_doctors %}
                <div class="doctor-mobile-card mb-3 rounded-4 shadow-sm p-0 overflow-hidden" style="background: white; border: 1px solid rgba(0,0,0,0.05);">
                    <!-- Card Header: Avatar + Name + Badge -->
                    <div class="d-flex align-items-center gap-3 p-3 border-bottom" style="background: linear-gradient(135deg, rgba(99,102,241,0.05), rgba(139,92,246,0.05));">
                        <div class="position-relative flex-shrink-0">
                            <img src="{{ dr.user.avatar|default('/img/default-doctor.png') }}"
                                 class="rounded-circle shadow-sm border border-2 border-white"
                                 style="width: 60px; height: 60px; object-fit: cover;" alt="">
                            <span class="position-absolute bottom-0 end-0 {{ dr.isActive ? 'bg-success' : 'bg-secondary' }} border border-2 border-white rounded-circle"
                                  style="width: 14px; height: 14px;"></span>
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <div class="fw-bold text-dark fs-6">
                                {{ dr.user.firstName or dr.user.lastName ? dr.user.firstName ~ ' ' ~ dr.user.lastName : dr.user.email|split('@')[0]|capitalize }}
                            </div>
                            <div class="text-muted small">{{ dr.roleType|capitalize|trans|default('') }}</div>
                            <div class="mt-1">
                                <span class="badge bg-primary-subtle text-primary rounded-pill px-2 py-1 small">
                                    {{ dr.specialty|default(dr.department.name|default('General'|trans)) }}
                                </span>
                            </div>
                        </div>
                        <div class="flex-shrink-0">
                            <span class="badge {{ dr.isActive ? 'bg-success-subtle text-success' : 'bg-secondary-subtle text-secondary' }} rounded-pill px-2 py-1 small">
                                {{ dr.isActive ? '● Active' : '● Offline' }}
                            </span>
                        </div>
                    </div>

                    <!-- Card Body: Hospital + Contact -->
                    <div class="px-3 py-2">
                        <div class="d-flex flex-wrap gap-3 small text-muted py-1">
                            <div class="d-flex align-items-center gap-1">
                                <i class="bi bi-hospital text-primary opacity-75"></i>
                                <span>{{ dr.hospital.name|default('EClinic Health') }}</span>
                            </div>
                            <div class="d-flex align-items-center gap-1">
                                <i class="bi bi-envelope text-primary opacity-75"></i>
                                <span class="text-truncate" style="max-width: 180px;">{{ dr.user.email }}</span>
                            </div>
                            {% if dr.phone %}
                            <div class="d-flex align-items-center gap-1">
                                <i class="bi bi-telephone text-primary opacity-75"></i>
                                <span>{{ dr.phone }}</span>
                            </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Card Footer: Action buttons -->
                    <div class="d-flex gap-2 px-3 pb-3 pt-1">
                        <a href="{{ path('app_consultation_new', {
                            'doctor': dr.id,
                            'hospital': dr.hospital.id|default(''),
                            'department': dr.department.id|default('')
                        }) }}" class="btn btn-sm flex-grow-1 rounded-pill fw-bold text-white shadow-sm" style="background: var(--brand-gradient); border: none; padding: 10px 0;">
                            <i class="bi bi-calendar-plus me-1"></i> {{ 'Book'|trans }}
                        </a>
                        <a href="{{ path('app_profile_chat', {'doctorId': dr.id}) }}" class="btn btn-sm btn-outline-primary flex-grow-1 rounded-pill fw-bold" style="padding: 10px 0;">
                            <i class="bi bi-chat-dots me-1"></i> {{ 'Message'|trans }}
                        </a>
                    </div>
                </div>
            {% else %}
                <!-- Empty state (mobile) -->
                <div class="text-center py-5 px-4">
                    <div class="empty-state-icon mb-4 mx-auto rounded-circle d-flex align-items-center justify-content-center" style="width: 90px; height: 90px; background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(139,92,246,0.1));">
                        <i class="bi bi-people fs-1 text-primary opacity-50"></i>
                    </div>
                    <h4 class="fw-bold text-dark mb-2">{{ 'No doctors found.'|trans }}</h4>
                    <p class="text-muted mb-4 small">{{ 'You haven\'t had any consultations yet.'|trans }}</p>
                    <a href="{{ path('app_hospital_public_list') }}" class="btn btn-primary rounded-pill px-5 py-2 fw-bold" style="background: var(--brand-gradient); border: none;">
                        {{ 'Browse Hospitals'|trans }}
                    </a>
                </div>
            {% endfor %}
        </div>

        {# ─────────────── DESKTOP TABLE (hidden on mobile) ─────────────── #}
        <div class="d-none d-md-block">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="background: var(--surface-color);">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-muted small text-uppercase tracking-wider">
                                <tr>
                                    <th class="ps-4 py-3 border-0">{{ 'Doctor'|trans }}</th>
                                    <th class="border-0">{{ 'Specialty'|trans }}</th>
                                    <th class="border-0">{{ 'Hospital'|trans }}</th>
                                    <th class="border-0">{{ 'Contact'|trans }}</th>
                                    <th class="border-0 pe-4 text-end">{{ 'Actions'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for dr in my_doctors %}
                                    <tr class="transition-all">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-3 py-2">
                                                <div class="position-relative">
                                                    <img src="{{ dr.user.avatar|default('/img/default-doctor.png') }}"
                                                         class="rounded-circle shadow-sm border border-2 border-white"
                                                         style="width: 50px; height: 50px; object-fit: cover;" alt="">
                                                    <span class="position-absolute bottom-0 end-0 {{ dr.isActive ? 'bg-success' : 'bg-secondary' }} border border-2 border-white rounded-circle"
                                                          style="width: 12px; height: 12px;"></span>
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark">{{ dr.user.firstName or dr.user.lastName ? dr.user.firstName ~ ' ' ~ dr.user.lastName : dr.user.email|split('@')[0]|capitalize }}</div>
                                                    <div class="text-muted small">{{ dr.roleType|capitalize|trans|default('') }}</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="badge bg-primary-subtle text-primary rounded-pill px-3 py-1 small">
                                                {{ dr.specialty|default(dr.department.name|default('General'|trans)) }}
                                            </div>
                                        </td>
                                        <td>
                                            <div class="small text-muted">
                                                <i class="bi bi-hospital me-1"></i> {{ dr.hospital.name|default('EClinic Health') }}
                                            </div>
                                        </td>
                                        <td>
                                            <div class="small mb-1"><i class="bi bi-envelope me-1"></i> {{ dr.user.email }}</div>
                                            {% if dr.phone %}
                                                <div class="small text-muted"><i class="bi bi-telephone me-1"></i> {{ dr.phone }}</div>
                                            {% endif %}
                                        </td>
                                        <td class="pe-4 text-end">
                                            <div class="d-flex justify-content-end gap-2">
                                                <a href="{{ path('app_consultation_new', {
                                                    'doctor': dr.id,
                                                    'hospital': dr.hospital.id|default(''),
                                                    'department': dr.department.id|default('')
                                                }) }}" class="btn btn-sm btn-gradient-purple rounded-pill px-3 shadow-sm fw-bold">
                                                    <i class="bi bi-calendar-plus me-1"></i> {{ 'Book'|trans }}
                                                </a>
                                                <a href="{{ path('app_profile_chat', {'doctorId': dr.id}) }}" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm fw-bold d-flex align-items-center gap-2">
                                                    <i class="bi bi-chat-dots"></i> {{ 'Message'|trans }}
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <div class="py-5">
                                                <i class="bi bi-people fs-1 text-muted opacity-25 d-block mb-3"></i>
                                                <h4 class="text-muted fw-bold">{{ 'No doctors found.'|trans }}</h4>
                                                <p class="text-muted mb-4">{{ 'You haven\'t had any consultations yet.'|trans }}</p>
                                                <a href="{{ path('app_hospital_public_list') }}" class="btn btn-primary rounded-pill px-4" style="width: fit-content; min-width: 180px;">
                                                    {{ 'Browse Hospitals'|trans }}
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .doctors-hero {
        position: relative;
        overflow: hidden;
    }
    .doctors-hero::before {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background-image:
            radial-gradient(circle at 10% 20%, rgba(255,255,255,0.1) 0%, transparent 40%),
            radial-gradient(circle at 90% 80%, rgba(255,255,255,0.05) 0%, transparent 40%);
    }
    .btn-white {
        background: var(--surface-color);
        color: var(--brand-color);
        border: none;
        transition: all 0.3s ease;
    }
    .btn-white:hover {
        background: #f8f9fa;
        transform: translateY(-2px);
        color: var(--brand-color);
    }
    .transition-all { transition: all 0.3s ease; }
    .btn-gradient-purple {
        background: linear-gradient(135deg, var(--brand-color), var(--accent-color));
        color: white;
        border: none;
    }
    .btn-gradient-purple:hover {
        filter: brightness(1.1);
        transform: translateY(-1px);
        box-shadow: 0 5px 15px rgba(99,102,241,0.3);
        color: white;
    }
    /* Mobile card animations */
    .doctor-mobile-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        animation: slideUp 0.4s ease forwards;
    }
    .doctor-mobile-card:active {
        transform: scale(0.98);
    }
    @keyframes slideUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .doctor-mobile-card:nth-child(1) { animation-delay: 0.05s; }
    .doctor-mobile-card:nth-child(2) { animation-delay: 0.10s; }
    .doctor-mobile-card:nth-child(3) { animation-delay: 0.15s; }
    .doctor-mobile-card:nth-child(4) { animation-delay: 0.20s; }
</style>
{% endblock %}

