{% extends 'frontend_layout/index.html.twig' %}

{% block title %}{{ 'Notifications'|trans }}{% endblock %}

{% block body %}
<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="fw-bold mb-0"><i class="bi bi-bell me-2 text-primary"></i>{{ 'Notifications'|trans }}</h2>
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-primary rounded-pill">{{ notifications|length }}</span>
                    <a href="javascript:void(0)" id="mark-all-read" class="text-primary small text-decoration-none hover-underline">{{ 'Mark all as read'|trans }}</a>
                </div>
            </div>

            {% if notifications is empty %}
                <div class="card border-0 shadow-sm rounded-4 text-center py-5">
                    <div class="card-body">
                        <i class="bi bi-bell-slash display-1 text-muted opacity-25 mb-3"></i>
                        <h4 class="text-muted">{{ 'No notifications yet'|trans }}</h4>
                        <p class="text-muted small">{{ 'We will notify you when something important happens.'|trans }}</p>
                    </div>
                </div>
            {% else %}
                <div class="list-group list-group-flush rounded-4 shadow-sm overflow-hidden border-0">
                    {% for notification in notifications %}
                        <a href="{{ notification.link|default('#') }}" 
                           class="list-group-item list-group-item-action p-4 border-0 mb-3 rounded-4 shadow-sm transition-all hover-translate-y notification-item {{ notification.isRead ? 'read' : 'unread' }}"
                           data-id="{{ notification.id }}"
                           style="{{ notification.isRead ? 'background: white;' : 'background: #f0f7ff; border-left: 4px solid var(--brand-color) !important;' }}">
                            <div class="d-flex w-100 justify-content-between align-items-start">
                                <div class="d-flex gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" 
                                         style="width: 48px; height: 48px; background: {{ notification.isRead ? 'rgba(0,0,0,0.05)' : 'rgba(99, 102, 241, 0.1)' }};">
                                        {% if notification.type == 'consultation' %}
                                            <i class="bi bi-calendar-check {{ notification.isRead ? 'text-muted' : 'text-primary' }} fs-4"></i>
                                        {% elseif notification.type == 'chat' %}
                                            <i class="bi bi-chat-dots {{ notification.isRead ? 'text-muted' : 'text-success' }} fs-4"></i>
                                        {% else %}
                                            <i class="bi bi-info-circle {{ notification.isRead ? 'text-muted' : 'text-info' }} fs-4"></i>
                                        {% endif %}
                                    </div>
                                    <div>
                                        <h6 class="mb-1 fw-bold {{ notification.isRead ? 'text-dark' : 'text-primary' }}">{{ notification.title|trans }}</h6>
                                        <p class="mb-1 text-muted small">{{ notification.message|trans }}</p>
                                        <small class="text-muted opacity-75">
                                            <i class="bi bi-clock me-1"></i>{{ notification.createdAt|date('d M Y, H:i') }}
                                        </small>
                                    </div>
                                </div>
                                {% if not notification.isRead %}
                                    <span class="badge bg-primary rounded-pill unread-dot" style="width: 10px; height: 10px; padding: 0;"> </span>
                                {% endif %}
                            </div>
                        </a>
                    {% endfor %}
                </div>

                {% if totalPages > 1 %}
                    <nav class="mt-5 d-flex justify-content-center">
                        <ul class="pagination pagination-rounded gap-2">
                            <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                                <a class="page-link border-0 shadow-sm rounded-circle d-flex align-items-center justify-content-center" 
                                   style="width: 40px; height: 40px;"
                                   href="{{ path('app_profile_notifications', {page: currentPage - 1}) }}">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            
                            {% for i in 1..totalPages %}
                                <li class="page-item {{ i == currentPage ? 'active' : '' }}">
                                    <a class="page-link border-0 shadow-sm rounded-circle d-flex align-items-center justify-content-center" 
                                       style="width: 40px; height: 40px; {{ i == currentPage ? 'background: var(--brand-gradient); color: white;' : 'background: white;' }}"
                                       href="{{ path('app_profile_notifications', {page: i}) }}">{{ i }}</a>
                                </li>
                            {% endfor %}

                            <li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
                                <a class="page-link border-0 shadow-sm rounded-circle d-flex align-items-center justify-content-center" 
                                   href="{{ path('app_profile_notifications', {page: currentPage + 1}) }}">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                {% endif %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
