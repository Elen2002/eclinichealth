{% extends 'frontend_layout/index.html.twig' %}

{% block title %}{{ 'My Profile'|trans }}{% endblock %}

{% block body %}
<div class="profile-page bg-light min-vh-100 mt-5 pt-4">
    <!-- Profile Header/Hero -->
    <div class="profile-hero py-5 mb-5" style="background: linear-gradient(135deg, var(--brand-color), var(--accent-color));">
        <div class="container position-relative" style="z-index: 1;">
            <div class="row align-items-center">
                <div class="col-md-auto text-center text-md-start mb-3 mb-md-0">
                    <div class="position-relative d-inline-block">
                        <img src="{{ user.avatar|default('/img/default-avatar.png') }}" 
                             class="rounded-circle border border-4 border-white shadow-lg" 
                             style="width: 130px; height: 130px; object-fit: cover;" alt="Profile">
                        <a href="{{ path('app_profile_edit') }}" class="position-absolute bottom-0 end-0 bg-white rounded-circle p-2 shadow-sm border" style="width: 38px; height: 38px; line-height: 22px; text-align: center; background: var(--surface-color) !important;">
                            <i class="bi bi-camera-fill text-primary small"></i>
                        </a>
                    </div>
                </div>
                <div class="col text-center text-md-start text-white">
                    <h1 class="fw-bold mb-1 text-white">{{ user.firstName ? user.firstName ~ ' ' ~ user.lastName : user.email|split('@')[0]|capitalize }}</h1>
                    <p class="text-white-50 mb-3"><i class="bi bi-envelope me-1"></i> {{ user.email }}</p>
                    <div class="d-flex flex-wrap justify-content-center justify-content-md-start gap-3">
                        <div class="bg-white bg-opacity-10 rounded-pill px-3 py-1 small">
                            <i class="bi bi-calendar-check me-1"></i> {{ consultations|length }} {{ 'Appointments'|trans }}
                        </div>
                        <div class="bg-white bg-opacity-10 rounded-pill px-3 py-1 small">
                            <i class="bi bi-shield-check me-1"></i> {{ 'Verified Account'|trans }}
                        </div>
                    </div>
                </div>
                <div class="col-md-auto mt-4 mt-md-0 text-center text-md-end">
                    <a href="{{ path('app_profile_edit') }}" class="btn btn-white rounded-pill px-4 fw-bold shadow-sm">
                        <i class="bi bi-pencil-square me-1"></i> {{ 'Edit Profile'|trans }}
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="container pb-5">
        <div class="row">
            <!-- Left Sidebar -->
            <div class="col-lg-4">
                <!-- Quick Stats -->
                <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                    <div class="card-body p-4">
                        <h6 class="fw-bold text-muted text-uppercase small mb-4 tracking-wider">{{ 'Personal Information'|trans }}</h6>
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary-subtle text-primary rounded-circle p-2 me-3">
                                <i class="bi bi-person"></i>
                            </div>
                            <div>
                                <div class="small text-muted">{{ 'Full Name'|trans }}</div>
                                <div class="fw-semibold">{{ user.firstName ~ ' ' ~ user.lastName }}</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center mb-0">
                            <div class="bg-info-subtle text-info rounded-circle p-2 me-3">
                                <i class="bi bi-telephone"></i>
                            </div>
                            <div>
                                <div class="small text-muted">{{ 'Phone Number'|trans }}</div>
                                <div class="fw-semibold">{{ user.phone|default('Not provided'|trans) }}</div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer border-top-0 p-0" style="background: linear-gradient(135deg, var(--brand-color), var(--accent-color));">
                        <a href="{{ path('app_logout') }}" class="btn btn-link w-100 py-3 text-white text-decoration-none border-top-0 rounded-0 fw-bold">
                            <i class="bi bi-box-arrow-right me-1 text-white"></i> {{ 'Logout'|trans }}
                        </a>
                    </div>
                </div>

            </div>

            <!-- Right Content -->
            <div class="col-lg-8">
                <!-- My Doctors Table Section -->
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4" style="background: var(--surface-color);">
                    <div class="card-header border-0 py-4 px-4 d-flex justify-content-between align-items-center" style="background: var(--surface-color);">
                        <h5 class="fw-bold mb-0"><i class="bi bi-heart-fill text-danger me-2"></i>{{ 'My Doctors'|trans }}</h5>
                        <a href="{{ path('app_profile_doctors') }}" class="btn btn-sm btn-white-modern rounded-pill px-3 shadow-sm border fw-bold" style="width: fit-content; min-width: 110px; font-size: 0.75rem;">
                            {{ 'View All'|trans }}
                        </a>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light text-muted small text-uppercase tracking-wider">
                                    <tr>
                                        <th class="ps-4 border-0">{{ 'Doctor'|trans }}</th>
                                        <th class="border-0">{{ 'Specialty'|trans }}</th>
                                        <th class="border-0">{{ 'Hospital'|trans }}</th>
                                        <th class="border-0 pe-4 text-end">{{ 'Action'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for dr in my_doctors %}
                                        <tr class="transition-all">
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center gap-3">
                                                    <img src="{{ dr.user.avatar|default('/img/default-doctor.png') }}" class="rounded-circle shadow-sm" style="width: 40px; height: 40px; object-fit: cover;" alt="">
                                                    <div class="fw-bold small">{{ dr.user.firstName ~ ' ' ~ dr.user.lastName }}</div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="badge bg-primary-subtle text-primary rounded-pill px-3 py-1 small">
                                                    {{ dr.specialty|default(dr.department.name|default('General'|trans)) }}
                                                </div>
                                            </td>
                                            <td>
                                                <div class="small text-muted">
                                                    <i class="bi bi-hospital me-1"></i> {{ dr.hospital.name|default('-') }}
                                                </div>
                                            </td>
                                            <td class="pe-4 text-end">
                                                <a href="{{ path('app_consultation_new', { 'doctor': dr.id, 'hospital': dr.hospital.id|default(''), 'department': dr.department.id|default('') }) }}" class="btn btn-sm btn-white-modern rounded-pill px-3 shadow-sm border fw-bold" style="font-size: 0.7rem;">
                                                    <i class="bi bi-calendar-plus me-1"></i> {{ 'Book Again'|trans }}
                                                </a>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="4" class="text-center py-4 text-muted">
                                                <p class="small mb-0">{{ 'No doctors assigned yet.'|trans }}</p>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Consultation History -->
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100" style="background: var(--surface-color);">
                    <div class="card-header border-0 py-4 px-4 d-flex justify-content-between align-items-center" style="background: var(--surface-color);">
                        <h5 class="fw-bold mb-0"><i class="bi bi-calendar2-week text-primary me-2"></i>{{ 'Appointment History'|trans }}</h5>
                        <a href="{{ path('app_hospital_public_list') }}" class="btn btn-sm btn-white-modern rounded-pill px-3 shadow-sm border ms-auto d-inline-flex align-items-center justify-content-center" style="width: fit-content; min-width: 160px; height: 34px; font-weight: 600; font-size: 0.75rem;">
                            <i class="bi bi-calendar-plus me-2"></i> {{ 'New Appointment'|trans }}
                        </a>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light text-muted small text-uppercase tracking-wider">
                                    <tr>
                                        <th class="ps-4 border-0">{{ 'Date'|trans }}</th>
                                        <th class="border-0">{{ 'Specialist'|trans }}</th>
                                        <th class="border-0">{{ 'Facility'|trans }}</th>
                                        <th class="border-0">{{ 'Status'|trans }}</th>
                                        <th class="border-0 pe-4"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for consultation in consultations %}
                                    <tr class="transition-all">
                                        <td class="ps-4">
                                            <div class="fw-bold text-dark">{{ consultation.requestedDate|date('M d, Y') }}</div>
                                            <div class="text-muted small">{{ consultation.requestedDate|date('H:i') }}</div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                                                    <i class="bi bi-person-badge text-primary"></i>
                                                </div>
                                                <div class="fw-semibold small">
                                                    {% if consultation.doctor and consultation.doctor.user %}
                                                        {{ consultation.doctor.user.firstName ~ ' ' ~ consultation.doctor.user.lastName }}
                                                    {% else %}
                                                        {{ 'Doctor'|trans }}
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="small text-muted">
                                                <i class="bi bi-hospital me-1"></i> {{ consultation.hospital.name|default('-') }}
                                            </div>
                                        </td>
                                        <td>
                                            {% if consultation.status == 'confirmed' %}
                                                <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2"><i class="bi bi-check-circle-fill me-1"></i> {{ 'Confirmed'|trans }}</span>
                                            {% elseif consultation.status == 'cancelled' %}
                                                <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-2"><i class="bi bi-x-circle-fill me-1"></i> {{ 'Cancelled'|trans }}</span>
                                            {% else %}
                                                <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-2"><i class="bi bi-clock-history me-1"></i> {{ 'Pending'|trans }}</span>
                                            {% endif %}
                                        </td>
                                        <td class="pe-4 text-end">
                                            <a href="{{ path('app_profile_consultation_detail', {'id': consultation.id}) }}" class="btn btn-sm btn-white-modern rounded-circle shadow-sm border" title="{{ 'View Details'|trans }}" style="width: 32px; height: 32px; padding: 0; line-height: 30px;">
                                                <i class="bi bi-chevron-right text-primary"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">
                                            <div class="py-5">
                                                <i class="bi bi-calendar-x fs-1 d-block mb-3 opacity-25"></i>
                                                <h5 class="fw-normal">{{ 'No appointment history found.'|trans }}</h5>
                                                <p class="small mb-4">{{ 'Your future medical requests will appear here.'|trans }}</p>
                                                <a href="{{ path('app_hospital_public_list') }}" class="btn btn-primary rounded-pill px-4" style="width: fit-content; min-width: 180px;">{{ 'Book Now'|trans }}</a>
                                            </div>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .profile-hero {
        position: relative;
        overflow: hidden;
    }
    .profile-hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.15) 0%, transparent 50%),
                          radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
    }
    .btn-white {
        background: var(--surface-color);
        color: var(--brand-color);
        border: none;
    }
    .btn-white:hover {
        background: #f8f9fa;
        transform: translateY(-2px);
    }
    .tracking-wider {
        letter-spacing: 0.05em;
    }
    .hover-bg-light:hover {
        background-color: #f8f9fa;
    }
    .transition-all {
        transition: all 0.3s ease;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(99, 102, 241, 0.02);
    }
    .btn-gradient-purple {
        background: linear-gradient(135deg, var(--brand-color), var(--accent-color));
        color: white;
        border: none;
    }
    .btn-white-modern {
        background: var(--surface-color) !important;
        color: var(--brand-color) !important;
        border: 1px solid #eee !important;
        transition: all 0.3s ease;
    }
    .btn-white-modern:hover {
        background: white !important;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.08) !important;
        border-color: var(--brand-color) !important;
    }
</style>
{% endblock %}
