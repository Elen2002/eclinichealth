{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block body %}
    <div class="dashboard-wrapper">
        <aside class="sidebar-nav">
            <a href="{{ path('app_home') }}" class="sidebar-logo text-decoration-none">
                <img src="{{ asset('build/img/header-logo.png') }}" alt="Logo" class="img-fluid" style="max-height: 40px;">
            </a>

            <nav>
                <div class="sidebar-section-label">{{ 'Management'|trans }}</div>
                <ul class="nav-list mb-3">
                    <li>
                        <a href="{{ path('app_super_admin_dashboard') }}" class="nav-item-link">
                            <i class="bi bi-hospital"></i>
                            <span>{{ 'Hospitals'|trans }}</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_department_index') }}" class="nav-item-link">
                            <i class="bi bi-diagram-3"></i>
                            <span>{{ 'Departments'|trans }}</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_doctor_index') }}" class="nav-item-link">
                            <i class="bi bi-people"></i>
                            <span>{{ 'Doctors'|trans }}</span>
                        </a>
                    </li>
                    <li>
                        <a href="#" class="nav-item-link">
                            <i class="bi bi-file-earmark-bar-graph"></i>
                            <span>{{ 'Reports'|trans }}</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_admin_support') }}" class="nav-item-link {{ app.request.attributes.get('_route') == 'app_admin_support' ? 'active' : '' }}">
                            <i class="bi bi-chat-left-dots"></i>
                            <span>{{ 'Support Chat'|trans }}</span>
                            <span id="chat-notification-badge" class="badge bg-danger rounded-pill ms-auto d-none">0</span>
                        </a>
                    </li>
                    <li>
                        <a href="#" class="nav-item-link">
                            <i class="bi bi-gear"></i>
                            <span>{{ 'Settings'|trans }}</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_home') }}" class="nav-item-link">
                            <i class="bi bi-globe"></i>
                            <span>{{ 'Return to Site'|trans }}</span>
                        </a>
                    </li>
                </ul>

            </nav>

            <div class="mt-auto">
                <a href="{{ path('app_logout') }}" class="nav-item-link text-danger">
                    <i class="bi bi-box-arrow-left"></i>
                    <span>{{ 'Logout'|trans }}</span>
                </a>
            </div>
        </aside>

        <main class="main-content">
            <header class="top-header">
                <div>
                    <h1 class="h3 mb-1" style="font-weight: 700; color: var(--heading-color);">{% block dashboard_title %}{{ 'Dashboard'|trans }}{% endblock %}</h1>
                    <p class="text-muted mb-0">{% block dashboard_subtitle %}{{ 'Welcome back!'|trans }}{% endblock %}</p>
                </div>

                <div class="header-actions">
                    <div class="dropdown">
                        <button class="lang-switcher-btn dropdown-toggle border-0" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-translate me-2"></i>{{ app.request.locale|upper }}
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-2 animate-fade-in" style="border-radius: 16px;">
                            <li><a class="dropdown-item rounded-3 small py-2" href="{{ path(app.request.attributes.get('_route', 'app_dashboard'), app.request.attributes.get('_route_params', [])|merge({'_locale': 'en'})) }}">🇺🇸 English</a></li>
                            <li><a class="dropdown-item rounded-3 small py-2" href="{{ path(app.request.attributes.get('_route', 'app_dashboard'), app.request.attributes.get('_route_params', [])|merge({'_locale': 'hy'})) }}">🇦🇲 Հայերեն</a></li>
                            <li><a class="dropdown-item rounded-3 small py-2" href="{{ path(app.request.attributes.get('_route', 'app_dashboard'), app.request.attributes.get('_route_params', [])|merge({'_locale': 'ru'})) }}">🇷🇺 Русский</a></li>
                        </ul>
                    </div>

                    <a href="{{ path('app_profile_notifications') }}" class="header-icon-btn text-decoration-none">
                        <i class="bi bi-bell text-dark"></i>
                        <div class="notification-dot"></div>
                    </a>

                    <div class="user-profile-pill">
                        <div class="user-avatar">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div class="d-none d-md-block">
                            <div class="small fw-bold text-dark mb-0" style="line-height: 1;">{{ app.user ? app.user.email|split('@')[0]|capitalize : 'Guest' }}</div>
                            <div class="text-muted" style="font-size: 0.65rem;">{{ app.user ? 'Administrator' : 'Not Logged In' }}</div>
                        </div>
                        <i class="bi bi-chevron-down small text-muted ms-1"></i>
                    </div>
                </div>
            </header>

            {% block dashboard_content %}{% endblock %}
        </main>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}
