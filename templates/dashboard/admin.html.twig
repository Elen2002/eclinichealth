{% extends 'dashboard_base.html.twig' %}

{% block title %}Admin Dashboard - eclinic-health{% endblock %}
{% block dashboard_title %}Admin Overview{% endblock %}
{% block dashboard_subtitle %}Manage clinic operations and staff{% endblock %}

{% block dashboard_nav %}{% endblock %}

{% block dashboard_content %}
    <div class="row">
        <div class="col-lg-12">
            <div class="action-bar mb-3">
                <div class="d-flex gap-2">
                    <div class="search-box position-relative">
                        <i class="bi bi-search position-absolute" style="left: 12px; top: 10px; color: #94a3b8;"></i>
                        <input type="text" class="form-control medical-input ps-5" placeholder="Search doctors..." style="width: 300px;">
                    </div>
                    <select class="form-select medical-input" style="width: 180px;">
                        <option selected>All Specialties</option>
                        <option>Cardiology</option>
                        <option>Neurology</option>
                        <option>Therapy</option>
                        <option>Surgery</option>
                    </select>
                </div>
                <div class="d-flex gap-2">
                    <form action="{{ path('app_doctor_import') }}" method="post" enctype="multipart/form-data" id="importForm" style="display: none;">
                        <input type="file" name="import_file" onchange="document.getElementById('importForm').submit()">
                    </form>
                    <button class="import-export-btn" onclick="document.querySelector('#importForm input').click()"><i class="bi bi-upload"></i> Import</button>
                    
                    <div class="dropdown">
                        <button class="import-export-btn dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="bi bi-download"></i> Export
                        </button>
                        <ul class="dropdown-menu border-0 shadow-lg">
                            <li><a class="dropdown-item" href="{{ path('app_doctor_export', {'type': 'excel'}) }}"><i class="bi bi-file-earmark-excel me-2"></i> Excel (CSV)</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_doctor_export', {'type': 'csv'}) }}"><i class="bi bi-file-earmark-text me-2"></i> CSV</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_doctor_export', {'type': 'doc'}) }}"><i class="bi bi-file-earmark-word me-2"></i> Word</a></li>
                        </ul>
                    </div>
                    
                    <button class="import-export-btn" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
                    <button type="button" class="medical-btn d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#addStaffModal">
                         <i class="bi bi-person-plus"></i> Add Doctor
                    </button>
                </div>
            </div>

            <div class="medical-card p-0 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-management mb-0">
                        <thead>
                            <tr>
                                <th>Doctor Name</th>
                                <th>Contact Info</th>
                                <th>Specialty</th>
                                <th>Department</th>
                                <th>Hospital</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for doctor in doctors %}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="bi bi-person-fill fs-5 text-primary"></i>
                                        </div>
                                        <div>
                                            <span class="d-block fw-bold text-dark">{{ doctor.user.email }}</span>
                                            <span class="small text-muted">ID: EC-D-{{ doctor.id }}</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column small">
                                        <span class="text-muted"><i class="bi bi-envelope me-1"></i> {{ doctor.user.email }}</span>
                                        <span class="text-muted"><i class="bi bi-telephone me-1"></i> {{ doctor.phone|default('N/A') }}</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">{{ doctor.specialty|default('General') }}</span>
                                </td>
                                <td>
                                    {{ doctor.department.name|default('-') }}
                                </td>
                                <td>
                                    {% if doctor.hospital %}
                                    <span class="badge bg-primary-subtle text-primary">{{ doctor.hospital.name }}</span>
                                    {% else %}
                                    <span class="text-muted small">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if doctor.isActive %}
                                        <span class="badge bg-success-subtle text-success">Active</span>
                                    {% else %}
                                        <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        {# View/Edit links #}
                                        <button class="btn btn-sm btn-light text-primary border-0"><i class="bi bi-pencil-square"></i></button>
                                        <button class="btn btn-sm btn-light text-danger border-0"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <p class="text-muted">No doctors found.</p>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Modals for Add/Edit (Staff) -->
    <div class="modal fade" id="addStaffModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-header border-0 p-4">
                    <h5 class="modal-title fw-bold">Onboard New Medical Practitioner</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 pt-0">
                    {{ form_start(doctor_form, {'action': path('app_doctor_new')}) }}
                        <div class="row gy-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Full Name</label>
                                {{ form_widget(doctor_form.name, {'attr': {'class': 'form-control medical-input', 'placeholder': 'Dr. John Doe'}}) }}
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Professional Email</label>
                                {{ form_widget(doctor_form.email, {'attr': {'class': 'form-control medical-input', 'placeholder': 'john.d@clinic.health'}}) }}
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Specialty</label>
                                {{ form_widget(doctor_form.specialty, {'attr': {'class': 'form-control medical-input'}}) }}
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Department Assignment</label>
                                {{ form_widget(doctor_form.department, {'attr': {'class': 'form-select medical-input'}}) }}
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Hospital Branch</label>
                                {{ form_widget(doctor_form.hospital, {'attr': {'class': 'form-select medical-input'}}) }}
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Clinical Role</label>
                                {{ form_widget(doctor_form.roleType, {'attr': {'class': 'form-control medical-input', 'placeholder': 'Surgeon / Therapist'}}) }}
                            </div>
                        </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="submit" class="medical-btn w-100 justify-content-center">Complete Registration</button>
                </div>
                {{ form_end(doctor_form) }}
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Table Search
    const searchInput = document.querySelector('.search-box input');
    const tableRows = document.querySelectorAll('.table-management tbody tr');
    
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            const query = this.value.toLowerCase();
            tableRows.forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(query) ? '' : 'none';
            });
        });
    }
});
</script>
{% endblock %}
