<div class="d-md-none fixed-bottom border-top pb-3 pt-2" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); z-index: 1040; box-shadow: 0 -4px 20px rgba(0,0,0,0.08);">
    <div class="row g-0 text-center align-items-end">
        <div class="col">
            <a href="{{ path('app_home') }}" class="text-decoration-none d-block py-1 {{ app.request.attributes.get('_route') == 'app_home' ? 'text-primary' : 'text-muted' }}">
                <i class="bi bi-house{{ app.request.attributes.get('_route') == 'app_home' ? '-fill' : '' }} fs-4 mb-1 d-block"></i>
                <span style="font-size: 11px; font-weight: {{ app.request.attributes.get('_route') == 'app_home' ? '600' : '400' }};">{{ 'Home'|trans }}</span>
            </a>
        </div>
        <div class="col">
             <a href="{{ path('app_home') }}#doctors" class="text-decoration-none d-block py-1 text-muted">
                <i class="bi bi-people fs-4 mb-1 d-block"></i>
                <span style="font-size: 11px;">{{ 'Doctors'|trans }}</span>
            </a>
        </div>
        
        <!-- Center Action Button (New Appointment) -->
        <div class="col position-relative">
             <div class="position-absolute start-50 translate-middle-x" style="top: -35px;">
                 <a href="{{ path('app_consultation_new') }}" class="d-flex align-items-center justify-content-center rounded-circle text-white shadow-lg" 
                    style="width: 56px; height: 56px; background: linear-gradient(135deg, var(--brand-color), var(--accent-color)); border: 4px solid white;">
                    <i class="bi bi-plus-lg fs-3"></i>
                 </a>
             </div>
             <div class="mt-4 pt-1 text-muted" style="font-size: 11px;">{{ 'Book'|trans }}</div>
        </div>

        <div class="col">
             <a href="{{ path('app_home') }}#services" class="text-decoration-none d-block py-1 text-muted">
                <i class="bi bi-grid fs-4 mb-1 d-block"></i>
                <span style="font-size: 11px;">{{ 'Services'|trans }}</span>
            </a>
        </div>

        <div class="col">
            {% if app.user %}
                <a href="{{ path('app_profile') }}" class="text-decoration-none d-block py-1 {{ app.request.attributes.get('_route') == 'app_profile' ? 'text-primary' : 'text-muted' }}">
                    <i class="bi bi-person{{ app.request.attributes.get('_route') == 'app_profile' ? '-fill' : '' }} fs-4 mb-1 d-block"></i>
                    <span style="font-size: 11px; font-weight: {{ app.request.attributes.get('_route') == 'app_profile' ? '600' : '400' }};">{{ 'Profile'|trans }}</span>
                </a>
            {% else %}
                <a href="{{ path('app_login') }}" class="text-decoration-none d-block py-1 {{ app.request.attributes.get('_route') == 'app_login' ? 'text-primary' : 'text-muted' }}">
                    <i class="bi bi-box-arrow-in-right fs-4 mb-1 d-block"></i>
                    <span style="font-size: 11px; font-weight: {{ app.request.attributes.get('_route') == 'app_login' ? '600' : '400' }};">{{ 'Login'|trans }}</span>
                </a>
            {% endif %}
        </div>
    </div>
</div>
<!-- Safe Area Spacer -->
<div class="d-md-none" style="height: 85px;"></div>
